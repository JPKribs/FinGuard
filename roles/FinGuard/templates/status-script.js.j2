const statusDataPath = '/var/www/html/status/status.json';

function updateStatus() {
    fetch(statusDataPath + '?' + new Date().getTime())
        .then(response => response.json())
        .then(data => {
            console.log("Data loaded:", data); 

            // System information
            document.getElementById('uptime').textContent = data.uptime;
            document.getElementById('cpu-usage').textContent = data.cpu_usage + '%';
            document.getElementById('cpu-bar').style.width = data.cpu_usage + '%';
            document.getElementById('memory-usage').textContent = 
                data.memory_used + ' / ' + data.memory_total + ' MB (' + data.memory_usage + '%)';
            document.getElementById('memory-bar').style.width = data.memory_usage + '%';
            document.getElementById('disk-usage').textContent = 
                data.disk_used + ' / ' + data.disk_total + ' GB (' + data.disk_usage + '%)';
            document.getElementById('disk-bar').style.width = data.disk_usage + '%';

            // Service status
            updateServiceStatus('wireguard-status', data.services.wireguard);
            updateServiceStatus('nginx-status', data.services.nginx);
            updateServiceStatus('jellyfin-proxy-status', data.services.jellyfin_proxy);

            // Network information
            const networkTable = document.getElementById('network-table');
            while (networkTable.rows.length > 1) {
                networkTable.deleteRow(1); // Clear existing rows
            }

            if (data.network && data.network.length > 0) {
                data.network.forEach(iface => {
                    const row = networkTable.insertRow();
                    const nameCell = row.insertCell(0);
                    const ipCell = row.insertCell(1);
                    const statusCell = row.insertCell(2);

                    nameCell.textContent = iface.name || 'Unknown';
                    ipCell.textContent = iface.ip || 'N/A';

                    const statusIndicator = document.createElement('span');
                    statusIndicator.className = 'status-indicator ' + 
                        ((iface.status === 'up') ? 'status-online' : 'status-offline');

                    statusCell.appendChild(statusIndicator);
                    statusCell.appendChild(document.createTextNode(
                        (iface.status === 'up') ? 'Up' : 'Down'
                    ));
                });
            }

            // Timer information
            if (data.timers) {
                document.getElementById('status-update-remaining').textContent = data.timers.status_update_remaining || 'Never';
                document.getElementById('ssl-renewal-timer').textContent = data.timers.ssl_renewal || 'Never';
                document.getElementById('finguard-update-timer').textContent = data.timers.finguard_update || 'Never';
            }

            // Update last updated time
            document.getElementById('last-updated').textContent = data.last_updated || new Date().toLocaleString();
        })
        .catch(error => {
            console.error('Error fetching status data:', error);
        });
}

function updateServiceStatus(elementId, status) {
    const element = document.getElementById(elementId);
    if (!element) return;

    const indicator = element.querySelector('.status-indicator');
    if (!indicator) return;

    const isRunning = (status === 'running' || status === 'active');
    
    indicator.className = 'status-indicator ' + 
        (isRunning ? 'status-online' : 'status-offline');

    while (element.lastChild) {
        if (element.lastChild.nodeType === Node.ELEMENT_NODE) {
            break;
        }
        element.removeChild(element.lastChild);
    }

    element.appendChild(document.createTextNode(
        isRunning ? 'Running' : 'Stopped'
    ));
}

updateStatus();
setInterval(updateStatus, 30000);