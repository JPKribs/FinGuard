#!/bin/bash
# Generate status data for dashboard

# Set WG_INTERFACE from template variable
WG_INTERFACE="{{ wg_interface }}"

# Function to get the most recent run between service and timer
get_last_run() {
  local service_name=$1
  local timer_name=$2

  service_time=$(systemctl show -p ExecMainStartTimestampMonotonic "${service_name}" | awk -F= '{print $2}')
  timer_time=$(systemctl show -p LastTriggerUSec "${timer_name}" | awk -F= '{print $2}')

  # Default to zero if unset
  service_time=${service_time:-0}
  timer_time=${timer_time:-0}

  # Pick the latest
  if [ "$service_time" -gt "$timer_time" ]; then
    date -d "@$((service_time / 1000000))" "+%Y-%m-%d %H:%M:%S"
  elif [ "$timer_time" -gt 0 ]; then
    date -d "@$((timer_time / 1000000))" "+%Y-%m-%d %H:%M:%S"
  else
    echo "Never"
  fi
}

# Get last runs
UPDATE_LAST_RUN=$(get_last_run "status-update.service" "status-update.timer")
SSL_LAST_RUN=$(get_last_run "renew-ssl-cert.service" "renew-ssl-cert.timer")
FINGUARD_LAST_RUN=$(get_last_run "finguard-update.service" "finguard-update.timer")

# Create JSON structure with safer network handling
cat > /var/www/html/status/status.json << EOF
{
  "uptime": "$(uptime -p 2>/dev/null | sed "s/up //" || echo "Unknown")",
  "cpu_usage": $(top -bn1 2>/dev/null | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{print 100 - $1}' | cut -d. -f1 || echo 0),
  "memory_total": $(free -m 2>/dev/null | awk '/Mem:/ {print $2}' || echo 0),
  "memory_used": $(free -m 2>/dev/null | awk '/Mem:/ {print $3}' || echo 0),
  "memory_usage": $(free 2>/dev/null | awk '/Mem:/ {printf("%.0f", ($3/$2) * 100)}' || echo 0),
  "disk_total": "$(df -h / 2>/dev/null | awk '/\// {print $2}' | sed 's/G//' || echo 0)",
  "disk_used": "$(df -h / 2>/dev/null | awk '/\// {print $3}' | sed 's/G//' || echo 0)",
  "disk_usage": $(df -h / 2>/dev/null | awk '/\// {print $5}' | sed 's/%//' || echo 0),
  "services": {
    "wireguard": "running",
    "nginx": "running",
    "jellyfin_proxy": "running"
  },
  "timers": {
    "status_update": "${UPDATE_LAST_RUN}",
    "ssl_renewal": "${SSL_LAST_RUN}",
    "finguard_update": "${FINGUARD_LAST_RUN}"
  },
  "network": [
$(for iface in $(ip -br link show up | awk '{print $1}'); do
  ipaddr=$(ip -br addr show $iface | awk '{print $3}' | cut -d/ -f1)
  if [ ! -z "$ipaddr" ]; then
    echo "    { \"name\": \"$iface\", \"ip\": \"$ipaddr\", \"status\": \"up\" }"
    if [ "$iface" != "$(ip -br link show up | tail -n1 | awk '{print $1}')" ]; then
      echo ","
    fi
  fi
done)
  ],
  "last_updated": "$(date)"
}
EOF

# Set permissions
chmod 644 /var/www/html/status/status.json