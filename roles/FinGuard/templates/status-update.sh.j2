#!/bin/bash

get_timer_remaining() {
  local timer_name=$1
  next_trigger=$(systemctl show "$timer_name" -p NextElapseUSec | awk -F= '{print $2}' || echo 0)
  if [[ "$next_trigger" -eq 0 ]]; then
    echo "Never"
    return
  fi
  current_time=$(date +%s)
  next_trigger_seconds=$((next_trigger / 1000000))
  remaining_seconds=$((next_trigger_seconds - current_time))
  minutes=$((remaining_seconds / 60))
  seconds=$((remaining_seconds % 60))
  echo "$minutes minutes $seconds seconds left"
}

UPDATE_LAST_RUN=$(systemctl show "status-update.service" -p ActiveEnterTimestamp | awk -F= '{print $2}')
SSL_LAST_RUN=$(systemctl show "renew-ssl-cert.service" -p ActiveEnterTimestamp | awk -F= '{print $2}')
FINGUARD_LAST_RUN=$(systemctl show "finguard-update.service" -p ActiveEnterTimestamp | awk -F= '{print $2}')
STATUS_UPDATE_REMAINING=$(get_timer_remaining "status-update.timer")
UPTIME=$(uptime -p 2>/dev/null | sed "s/up //" || echo "Unknown")
CPU_USAGE=$(top -bn1 2>/dev/null | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{print 100 - $1}' | cut -d. -f1 || echo 0)
MEMORY_TOTAL=$(free -m 2>/dev/null | awk '/Mem:/ {print $2}' || echo 0)
MEMORY_USED=$(free -m 2>/dev/null | awk '/Mem:/ {print $3}' || echo 0)
MEMORY_USAGE=$(free 2>/dev/null | awk '/Mem:/ {printf("%.0f", ($3/$2) * 100)}' || echo 0)
DISK_TOTAL=$(df -h / 2>/dev/null | awk '/\// {print $2}' | sed 's/G//' || echo 0)
DISK_USED=$(df -h / 2>/dev/null | awk '/\// {print $3}' | sed 's/G//' || echo 0)
DISK_USAGE=$(df -h / 2>/dev/null | awk '/\// {print $5}' | sed 's/%//' || echo 0)

cat > /var/www/html/status/status.json << EOF
{
  "uptime": "$UPTIME",
  "cpu_usage": $CPU_USAGE,
  "memory_total": $MEMORY_TOTAL,
  "memory_used": $MEMORY_USED,
  "memory_usage": $MEMORY_USAGE,
  "disk_total": "$DISK_TOTAL",
  "disk_used": "$DISK_USED",
  "disk_usage": $DISK_USAGE,
  "services": {
    "wireguard": "running",
    "nginx": "running",
    "jellyfin_proxy": "running"
  },
  "timers": {
    "status_update": "$UPDATE_LAST_RUN",
    "ssl_renewal": "$SSL_LAST_RUN",
    "finguard_update": "$FINGUARD_LAST_RUN",
    "status_update_remaining": "$STATUS_UPDATE_REMAINING"
  },
  "last_updated": "$(date)"
}
EOF

chmod 644 /var/www/html/status/status.json