[Unit]
Description=mDNS Hostname Publisher
After=avahi-daemon.service
Requires=avahi-daemon.service
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/mdns-publisher.sh
Restart=always
RestartSec=10
KillMode=mixed
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target