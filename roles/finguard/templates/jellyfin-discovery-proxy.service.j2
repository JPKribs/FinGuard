[Unit]
Description=Jellyfin Discovery Proxy Service
After=network.target

[Service]
ExecStart={{ binary_dest }}
Environment=JELLYFIN_SERVER_URL={{ jellyfin_server_url }}
Environment=PROXY_URL=http://{{ hostname }}.local   # {{ hostname }}.local advertised via mDNS
Restart=on-failure

[Install]
WantedBy=multi-user.target